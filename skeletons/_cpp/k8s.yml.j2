apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ app_name }}
  namespace: default
spec:
  replicas: 1
  selector:
    matchLabels:
      app: {{ app_name }}
  template:
    metadata:
      labels:
        app: {{ app_name }}
    spec:
      containers:
      - name: main
        image: "{{ registry_ip }}:{{ registry_port | default(5000) }}/{{ app_name }}:{{ app_hash }}"
        imagePullPolicy: Always  
      
      - name: health-sidecar
        image: alpine:latest
        command: ["/bin/sh", "-c"]
        args:
        - |
          apk add --no-cache wget # Ensure wget is present in alpine
          while true; do
            payload="{\"service\": \"{{ app_name }}\", \"status\": \"running\", \"host\": \"$NODE_NAME\"}"
            wget -q --post-data="$payload" http://{{ control_node_host }}:9090/health -O - || true
            sleep 30
          done
        env:
        - name: NODE_NAME
          valueFrom:
            fieldRef:
              fieldPath: spec.nodeName
