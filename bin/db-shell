#!/bin/bash

echo "Opening tunnel to K3s Postgres..."
# using 5433 in case we already run a psql dev container on control node at 5432
kubectl port-forward -n database svc/postgres-service 5433:5432 > /dev/null 2>&1 &

TUNNEL_PID=$!

# ensures tunnel is killed when shell is killed
trap "kill $TUNNEL_PID 2>/dev/null" EXIT

TIMEOUT=5
start_time=$(date +%s)

until pg_isready -h 127.0.0.1 -p 5433 > /dev/null 2>&1; do
    sleep 0.1
done

DB_SUPER_USER=$(yq '.db_super_user' group_vars/all.yml)
DB_INITIAL_NAME=$(yq '.db_initial_name' group_vars/all.yml)


psql -h 127.0.0.1 -p 5433 -U $DB_SUPER_USER -d $DB_INITIAL_NAME

echo "Tunnel closed."
